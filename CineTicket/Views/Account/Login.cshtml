@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <title>Login</title>
</head>

<body>
    <section class="bg-img d-flex align-items-center">
        <div class="container">
            <h1 class="fw-bold text-white mb-5 text-center"><i class="fa-solid fa-film text-danger"></i>CineTicket</h1>

            <div class="form-div mx-auto">
                <h3 class="fw-bold text-white text-center">Welcome Back!</h3>
                <form asp-controller="Account" asp-action="Login" class="text-white" method="post">

                    <div class="mt-3 mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control bg-dark text-white" name="Email" id="email">
                    </div>

                    <div class="mt-3 mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control bg-dark text-white" name="Password" id="password">
                    </div>

                    <div class="mt-3 mb-3">
                        <input type="checkbox" name="Checkbox" id="checkbox" class="form-check-input">
                        <label for="checkbox">Remember me</label>
                    </div>
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    <button class="btn btn-danger rounded-2 py-2 w-100 fw-bold">Login</button>

                    <div class="text-center mt-3 mb-3">
                        <h6 class="fw-bold text-center mb-3">Don't have an account?</h6>
                        <a asp-controller="Account" asp-action="Register" class="fw-bold text-decoration-none text-white lead">Create</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
    <!-- ============================= JAVA SCRIPT BAĞLANTISI ============================= -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
    <script src="~/js/script.js"></script>
</body>

</html>
