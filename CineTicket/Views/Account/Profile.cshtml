@model CineTicket.Models.User

@{
    ViewData["Title"] = "My Profile";
}
@section Styles {
    <style>
        .bg-input {
            background-color: rgba(108, 117, 125, 1) !important;
        }

            .bg-input:focus {
                background-color: rgba(108, 117, 125, 1);
            }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background-color: rgba(33,37,41,1) !important;
        }
    </style>
}
<section class="py-5" style="background-color: #1a1a1a; border-bottom: 1px solid #333;">
    <div class="container row g-4 mx-auto">
        <div class="col-12 col-lg-4">
            <div class="position-sticky" style="top: 5rem;">
                <div class="card bg-dark border-secondary d-flex justify-content-center align-items-center py-5">
                    <div class="avatar fw-bold d-flex justify-content-center align-items-center display-6 text-white">
                        @(Model.FirstName.Substring(0, 1).ToUpper() + Model.LastName.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <h2 class="fw-bold text-white mt-4">@Model.FirstName @Model.LastName</h2>
                    </div>
                </div>

                <div class="list-group mt-3 shadow">

                    <a href="#" class="list-group-item list-group-item-action active" id="personal">
                        <i class="me-3 fa-solid fa-address-card"></i> Personal Info
                    </a>

                    <a href="#" class="list-group-item list-group-item-action" id="tickets">
                        <i class="me-3 fa-solid fa-ticket"></i> My Tickets
                    </a>

                    <a href="#" class="list-group-item list-group-item-action" id="comments">
                        <i class="me-3 fa-regular fa-comment"></i> My Comments
                    </a>

                    <a href="#" class="list-group-item list-group-item-action" id="password">
                        <i class="me-3 fa-solid fa-lock"></i> Change Password
                    </a>

                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <!-- PERSONAL INFORMATION -->
            <div class="card bg-dark border-secondary p-4" id="personal-section">

                <h3 class="fw-bold text-white mb-4">Personal Information</h3>

                <form asp-action="UpdateProfile" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-white-50">First Name</label>
                            <input type="text" class="form-control text-white bg-input" value="@Model.FirstName" name="FirstName">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-white-50">Last Name</label>
                            <input type="text" class="form-control text-white bg-input" value="@Model.LastName" name="LastName">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-white-50">Email Address</label>
                        <input type="email" class="form-control text-white bg-input" value="@Model.EmailAddress" name="EmailAddress">
                    </div>

                    <button class="btn btn-danger px-4 py-2 fw-bold">Update Profile</button>
                </form>

            </div>
            <!-- MY TICKETS -->
            <div id="tickets-section"
                 class="card bg-dark border-secondary p-4 d-none">
                <h3 class="fw-bold text-white mb-4">
                    <i class="me-2 fa-solid fa-ticket"></i> My Tickets
                </h3>
                @if (Model.Tickets.Count == 0)
                {
                    <div class="alert alert-dark text-dark border-secondary text-center">
                        You haven't bought any tickets yet. Come on, grab a movie, come on!
                    </div>
                }
                else
                {
                    foreach (var ticket in Model.Tickets.OrderByDescending(t => t.Id))
                    {
                        <div class="card bg-dark border-secondary mb-3 ticket-card">
                            <div class="row g-0 align-items-center">

                                <div class="col-md-3 col-lg-2">
                                    <img src="@ticket.Movie.VerticalImageUrl" class="img-fluid rounded-start ticket-img"
                                         alt="@ticket.Movie.MovieName">
                                </div>

                                <div class="col-md-6 col-lg-7">
                                    <div class="card-body">
                                        <h3 class="card-title fw-bold text-danger">@ticket.Movie.MovieName</h3>

                                        <p class="text-white-50 mb-2">
                                            <i class="fa-regular fa-clock me-2"></i> @ticket.ShowTime
                                        </p>
                                        <p class="text-white-50 mb-3">
                                            <i class="fa-solid fa-location-dot me-2"></i> @ticket.City / @ticket.Hall
                                            Hall
                                        </p>

                                        <div>
                                            <span class="text-white fw-bold me-2"> Seats:</span>
                                            @foreach (var seat in ticket.SeatNumbers.Split(','))
                                            {
                                                <span class="badge bg-danger me-1">@seat</span>
                                            }
                                        </div>
                                        <div>
                                            <span class="mt-3 py-2 text-white fw-bold badge bg-danger">
                                                Total Price: @ticket.Price $
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-3 col-lg-3 p-3 text-center">
                                    <div class="pnr-box p-3 rounded-3">
                                        <small class="text-white-50 d-block mb-1">PNR CODE</small>
                                        <h4 class="text-white fw-bold mb-0 letter-spacing-2">@ticket.PnrCode</h4>
                                        <div class="mt-2 text-danger">
                                            <i class="fa-solid fa-qrcode fa-2x"></i>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                }

            </div>
            <!-- MY COMMENTS -->
            <div id="comments-section" class="d-none">
                <div class="card bg-dark border-secondary p-4">
                    <h3 class="fw-bold text-white mb-4">
                        <i class="me-2 fa-regular fa-comment"></i> My Comments
                    </h3>

                    @if (Model.Comments == null || Model.Comments.Count == 0)
                    {
                        <div class="alert alert-dark text-dark border-secondary text-center">
                            You haven't commented on any movie yet!
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.Id))
                        {
                            <div class="comment-box card bg-dark border-secondary p-4 mb-3 d-flex flex-row justify-content-between">
                                <div>
                                    <h3 class="fw-bold text-danger">@comment.Movie.MovieName</h3>
                                    <i class="text-white-50">"@comment.Content"</i>
                                </div>

                                <div>
                                    <form asp-controller="Account" asp-action="DeleteComment" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this comment?');">

                                        <input type="hidden" name="commentId" value="@comment.Id" />

                                        <button type="submit" class="btn btn-outline-danger float-end">
                                            <i class="fa-regular fa-trash-can"></i>
                                        </button>

                                    </form>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <!-- CHANGE PASSWORD -->
            <div class="card bg-dark border-secondary p-4 d-none" id="password-section">

                <h3 class="fw-bold text-white mb-4">
                    <i class="me-3 fa-solid fa-lock"></i> Change Password
                </h3>

                @if (TempData["PasswordError"] != null)
                {
                    <div class="alert alert-danger fw-bold">@TempData["PasswordError"]</div>
                }
                @if (TempData["PasswordSuccess"] != null)
                {
                    <div class="alert alert-success fw-bold">@TempData["PasswordSuccess"]</div>
                }
                <input type="hidden" id="has-password-message"
                       value="@(TempData["PasswordError"] != null
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      || TempData["PasswordSuccess"] != null ? "true" : "false")" />
                <div>
                    <form asp-action="ChangePassword" method="post">
                        <div class="row">
                            <div class="col-lg-12 mb-2 mt-2">
                                <label class="form-label fw-bold text-white-50">Current Password</label>
                                <input type="password" class="form-control mt-1 text-white bg-input"
                                       name="OldPassword"
                                       placeholder="Enter your old password">
                            </div>

                            <hr class="text-white-50 mt-4 mb-4">

                            <div class="col-lg-12 mt-2">
                                <label class="form-label fw-bold text-white-50">New Password</label>
                                <input type="password" class="form-control mt-1 text-white bg-input"
                                       name="NewPassword"
                                       placeholder="Enter new password">
                            </div>

                            <div class="col-lg-12 mt-3">
                                <label class="form-label fw-bold text-white-50">Confirm New Password</label>
                                <input type="password" class="form-control mt-1 text-white bg-input"
                                       name="ConfirmPassword"
                                       placeholder="Re-enter new password">
                            </div>
                        </div>

                        <button class="btn btn-danger rounded-2 mt-4 py-2 fw-bold">Update Password</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</section>