@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <title>Register</title>
</head>

<body>
    <section class="bg-img py-5">
        <div class="container">

            <div class="form-div mx-auto">
                <h1 class="fw-bold text-white mb-4 mt-0 text-center">
                    <i class="fa-solid fa-film text-danger"></i>CineTicket
                </h1>
                <h4 class="fw-bold text-white text-center ">Create Account</h4>
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center">
                        @ViewBag.Error
                    </div>
                }

                <form asp-controller="Account" asp-action="Register" class="text-white" method="post">

                    <div class="row">
                        <div class="col-md-6 mt-3 mb-3">
                            <label for="firstName" class="form-label">First Name</label>
                            <input type="text" class="form-control bg-dark text-white" name="FirstName" id="firstName">
                        </div>
                        <div class="col-md-6 mt-3 mb-3">
                            <label for="lastName" class="form-label">Last Name</label>
                            <input type="text" class="form-control bg-dark text-white" name="LastName" id="lastName">
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control bg-dark text-white" name="EmailAddress" id="email">
                    </div>

                    <div class="mt-3 mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control bg-dark text-white" name="Password" id="password">
                    </div>

                    <div class="mt-3 mb-3">
                        <label for="confirmPassword" class="form-label">Password Again</label>
                        <input type="password" class="form-control bg-dark text-white" name="ConfirmPassword" id="confirmPassword">
                    </div>

                    <div class="mt-3 mb-3">
                        <input type="checkbox" name="TermsAccepted" id="checkbox" class="form-check-input">
                        <label for="TermsAccepted">
                            I agree to the
                            <a href="#" class="text-decoration-none text-danger">Terms & Conditions</a>
                        </label>
                    </div>

                    <button class="btn btn-danger rounded-2 py-2 w-100 fw-bold mt-2">Register</button>

                    <div class="text-center mt-3 mb-3">
                        <h6 class="fw-bold text-center mb-3">Already have an account?</h6>
                        <a asp-controller="Account" asp-action="Login" class="fw-bold text-decoration-none text-white lead">Login here</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
    <!-- ============================= JAVA SCRIPT BAĞLANTISI ============================= -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
    <script src="script.js"></script>
</body>

</html>